[Unit]
Description=Smart Home Control Gunicorn Service
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/smart_home_control/backend
EnvironmentFile=/opt/smart_home_control/backend/.env
ExecStart=/opt/smart_home_control/backend/.venv/bin/gunicorn --workers 2 --bind 127.0.0.1:28681 --access-logfile - --error-logfile - wsgi:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
