# MQTT broker settings.
# Replace these with the same broker, username, password, and topic root
# that your ESP8266 firmware is using.
MQTT_HOST=your-emqx-host
MQTT_PORT=8883
MQTT_USERNAME=your-mqtt-username
MQTT_PASSWORD=your-mqtt-password
MQTT_TOPIC_ROOT=nodemcu

# Backend runtime settings.
MQTT_CLIENT_ID_PREFIX=smart-home-backend
MQTT_KEEPALIVE=60
MQTT_COMMAND_TIMEOUT=5
MQTT_USE_TLS=1
MQTT_TLS_INSECURE=0

# Web server settings.
WEB_HOST=127.0.0.1
WEB_PORT=28681
WEB_DEBUG=0
WEB_PROXY_FIX=1
